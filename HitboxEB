------------------------------------------------------------
--                      ESP MANAGER V6                    --
------------------------------------------------------------

local function RemoveESP(char)
    if not char then return end
    
    -- Remove Highlight (Brilho no corpo)
    local h = char:FindFirstChild("ESPHighlight")
    if h then h:Destroy() end
    
    -- Remove SelectionBox (Caixa da Hitbox Real)
    local s = char:FindFirstChild("HitboxBox")
    if s then s:Destroy() end
    
    -- Remove Texto de Amigo
    local head = char:FindFirstChild("Head")
    if head and head:FindFirstChild("FriendTag") then
        head.FriendTag:Destroy()
    end
end

local function ApplyESP(player)
    -- Se ESP estiver desligado, limpa tudo
    if not Config.ESPEnabled then 
        if player.Character then RemoveESP(player.Character) end
        return 
    end
    
    if not player or not player.Character then return end
    if player == LocalPlayer then return end -- Não aplicar em si mesmo

    local char = player.Character
    local targetPartObj = char:FindFirstChild(Config.TargetPart) or char:FindFirstChild("Head")

    -- 1. DEFINIÇÃO DA COR (Baseada no Time)
    local targetColor = Config.DefaultESPColor
    if player.TeamColor then
        targetColor = player.TeamColor.Color 
    end
    
    -- 2. HIGHLIGHT (Brilho no Corpo todo)
    if not char:FindFirstChild("ESPHighlight") then
        local hl = Instance.new("Highlight")
        hl.Name = "ESPHighlight"
        hl.Adornee = char
        hl.Parent = char
        hl.FillTransparency = 1 
        hl.OutlineColor = targetColor
        hl.OutlineTransparency = 0
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    end

    -- 3. SELECTION BOX (A SOLUÇÃO PARA HITBOX "INVISÍVEL")
    if targetPartObj and not char:FindFirstChild("HitboxBox") then
        local sb = Instance.new("SelectionBox")
        sb.Name = "HitboxBox"
        sb.Adornee = targetPartObj -- Cola na cabeça/parte alvo
        sb.Parent = char
        sb.Color3 = targetColor
        sb.LineThickness = 0.05
        sb.Transparency = 0.3
        sb.SurfaceTransparency = 0.8
    end

    -- 4. WHITELIST TAG (Texto "AMIGO")
    if Whitelist[player.Name] then
        local head = char:FindFirstChild("Head")
        if head and not head:FindFirstChild("FriendTag") then
            local bb = Instance.new("BillboardGui")
            bb.Name = "FriendTag"
            bb.Adornee = head
            bb.Size = UDim2.new(0, 100, 0, 40)
            bb.StudsOffset = Vector3.new(0, 3, 0)
            bb.AlwaysOnTop = true
            bb.Parent = head

            local txt = Instance.new("TextLabel")
            txt.Parent = bb
            txt.Size = UDim2.new(1, 0, 1, 0)
            txt.BackgroundTransparency = 1
            txt.Text = "Amizade"
            txt.TextColor3 = Color3.fromRGB(0, 255, 127)
            txt.TextStrokeTransparency = 0
            txt.Font = Enum.Font.GothamBlack
            txt.TextSize = 11
        end
    end
end

local function UpdateAllESP()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            if Config.ESPEnabled then
                ApplyESP(plr)
            else
                if plr.Character then RemoveESP(plr.Character) end
            end
        end
    end
end

------------------------------------------------------------
--                      HITBOX CORE                       --
------------------------------------------------------------

local function safeSetPartProps(part, props)
    if not part or not part:IsA("BasePart") then return end
    local ok, err = pcall(function()
        for k, v in pairs(props) do
            part[k] = v
        end
    end)
    if not ok then warn("safeSetPartProps error:", err) end
end

local function RestorePlayer(player)
    if not player or not player.Character then return end
    local char = player.Character
    
    -- Restaura Hitbox
    for _, child in pairs(char:GetChildren()) do
        if child:IsA("BasePart") and OriginalSizes[child] then
            -- CORREÇÃO AQUI: Verifica se é o RootPart para deixar invisível
            local originalTransparency = 0
            if child.Name == "HumanoidRootPart" then
                originalTransparency = 1
            end

            safeSetPartProps(child, {
                Size = OriginalSizes[child],
                Transparency = originalTransparency, -- Aplica a transparência correta
                CanCollide = true,
                Massless = false
            })
            OriginalSizes[child] = nil
        end
    end
    
    if not Config.ESPEnabled then RemoveESP(char) end
end

local function RestoreAll()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            RestorePlayer(plr)
        end
    end
    UpdateAllESP()
end

local function findTargetPart(char, target)
    if not char then return nil end
    local p = char:FindFirstChild(target)
    if p and p:IsA("BasePart") then return p end
    if target == "Torso" then
        return char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    end
    -- Se não achar nada, retorna a cabeça. Evitamos retornar HumanoidRootPart para hitbox visual.
    return char:FindFirstChild("Head") 
end

local function ApplyHitbox(player)
    if not Config.Enabled then return end
    if not player or not player.Character then return end
    
    if Config.IgnoreTeam and player.Team == LocalPlayer.Team then
        RestorePlayer(player)
        if Config.ESPEnabled then ApplyESP(player) end
        return
    end

    local part = findTargetPart(player.Character, Config.TargetPart)
    if part and part:IsA("BasePart") then
        if not OriginalSizes[part] then
            OriginalSizes[part] = part.Size
        end

        local desired = Vector3.new(Config.HitboxSize, Config.HitboxSize, Config.HitboxSize)

        if part.Size ~= desired then
            safeSetPartProps(part, { Size = desired, CanCollide = false, Massless = true })
        end
        if part.Transparency ~= Config.HitboxTransparency then
            safeSetPartProps(part, { Transparency = Config.HitboxTransparency })
        end
    end
end

RunService.RenderStepped:Connect(function()
    -- Lógica Hitbox
    if Config.Enabled then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer then
                ApplyHitbox(plr)
            end
        end
    end
    
    -- Garante que o ESP (Box, Highlight e Texto) esteja lá
    if Config.ESPEnabled then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                if not plr.Character:FindFirstChild("ESPHighlight") or 
                   not plr.Character:FindFirstChild("HitboxBox") then
                    ApplyESP(plr)
                end
            end
        end
    end
end)

Players.PlayerRemoving:Connect(function(plr) RestorePlayer(plr) end)

Players.PlayerAdded:Connect(function(plr)
    if plr.Character then
        ApplyESP(plr) 
        plr.CharacterRemoving:Connect(function() RestorePlayer(plr) end)
    end
    plr.CharacterAdded:Connect(function(char)
        task.wait(0.2) 
        if Config.ESPEnabled then ApplyESP(plr) end
        if not Config.Enabled then RestorePlayer(plr) end
    end)
end)

for _, plr in pairs(Players:GetPlayers()) do
    if plr ~= LocalPlayer then
        if plr.Character then
            if Config.ESPEnabled then ApplyESP(plr) end
            plr.CharacterRemoving:Connect(function() RestorePlayer(plr) end)
        end
        plr.CharacterAdded:Connect(function(char)
            task.wait(0.2)
            if Config.ESPEnabled then ApplyESP(plr) end
        end)
    end
end

