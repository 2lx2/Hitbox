-- Variável para cachear as partes originais e evitar lag
local OriginalSizes = {}

------------------------------------------------------------
--                  SISTEMA DE HITBOX                     --
------------------------------------------------------------

-- Função para resetar um jogador específico ao normal
local function RestorePlayer(player)
    if not player or not player.Character then return end
    
    local char = player.Character
    for _, child in pairs(char:GetChildren()) do
        if child:IsA("BasePart") and OriginalSizes[child] then
            child.Size = OriginalSizes[child]
            child.Transparency = 0
            child.CanCollide = true
            child.Massless = false
            OriginalSizes[child] = nil -- Limpa do cache
        end
    end
end

-- Função para resetar TODOS (usada ao desativar o script)
local function RestoreAll()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            RestorePlayer(plr)
        end
    end
end

-- Função principal de aplicar a hitbox
local function ApplyHitbox(player)
    if not Config.Enabled then return end
    if not player.Character then return end
    if Config.IgnoreTeam and player.Team == LocalPlayer.Team then 
        RestorePlayer(player) -- Se for do time, garante que está normal
        return 
    end

    local char = player.Character
    local part = char:FindFirstChild(Config.TargetPart)
    
    -- Tenta achar partes R15 ou R6 compativeis se não achar direto
    if not part then
        if Config.TargetPart == "Torso" then
            part = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
        else
            part = char:FindFirstChild(Config.TargetPart)
        end
    end

    if part and part:IsA("BasePart") then
        -- Salva o tamanho original se ainda não salvou
        if not OriginalSizes[part] then
            OriginalSizes[part] = part.Size
        end

        -- Aplica as mudanças
        part.Size = Vector3.new(Config.HitboxSize, Config.HitboxSize, Config.HitboxSize)
        part.Transparency = Config.HitboxTransparency
        part.CanCollide = false
        part.Massless = true
    end
end

-- Loop Principal (Otimizado)
RunService.RenderStepped:Connect(function()
    if not Config.Enabled then return end
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            ApplyHitbox(plr)
        end
    end
end)

