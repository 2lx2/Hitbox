    local parts = {"Head", "Torso"} 
    local index = 1
    for i, v in ipairs(parts) do
        if v == Config.TargetPart then index = i; break end
    end

    Button.MouseButton1Click:Connect(function()
        RestoreAll()
        index = index + 1
        if index > #parts then index = 1 end
        Config.TargetPart = parts[index]
        Button.Text = "Target: " .. Config.TargetPart
    end)
end

