    Button.TextColor3 = Color3.fromRGB(220,220,220)
    Button.Font = Enum.Font.GothamSemibold
    Button.TextSize = 13
    Button.Parent = Container

    local Corner = Instance.new("UICorner"); Corner.CornerRadius = UDim.new(0,6); Corner.Parent = Button
    local Stroke = Instance.new("UIStroke"); Stroke.Color = Color3.fromRGB(60,60,70); Stroke.Thickness = 1; Stroke.Parent = Button;

    local parts = {"Head", "HumanoidRootPart", "Torso"}
    local index = 1
    for i, v in ipairs(parts) do
        if v == Config.TargetPart then index = i; break end
    end

    Button.MouseButton1Click:Connect(function()
        RestoreAll()
        index = index + 1
        if index > #parts then index = 1 end
        Config.TargetPart = parts[index]
        Button.Text = "Target: " .. Config.TargetPart
    end)
end

