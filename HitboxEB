local Config = {
    HitboxSize = 6,
    HitboxTransparency = 0.8,
    IgnoreTeam = true, -- Esta opção agora afeta APENAS a Hitbox
    TargetPart = "Head", -- "Head", "HumanoidRootPart", "Torso"
    Enabled = false,
    ShowDot = false,
    -- Configurações ESP
    ESPEnabled = false,
    -- A cor é automática baseada no time, Default Red se sem time.
    DefaultESPColor = Color3.fromRGB(255, 40, 40) 
}

-- Weak table para evitar memory leaks quando partes são destruídas
local OriginalSizes = setmetatable({}, {__mode = "k"})

------------------------------------------------------------
--                      ESP MANAGER (AGORA GLOBAL)        --
------------------------------------------------------------

local function RemoveESP(char)
    if not char then return end
    local h = char:FindFirstChild("ESPHighlight")
    if h then h:Destroy() end
end

local function ApplyESP(player)
    -- Verificações básicas
    if not Config.ESPEnabled then 
        if player.Character then RemoveESP(player.Character) end
        return 
    end
    if not player or not player.Character then return end
    if player == LocalPlayer then return end -- EXCLUSÃO OBRIGATÓRIA: Não aplicar em si mesmo
    
    -- A MUDANÇA ESTÁ AQUI: Removemos a checagem de time (Config.IgnoreTeam)
    -- O ESP agora aplica-se a TODOS os outros jogadores.

    local char = player.Character
    
    -- Evita criar duplicados
    if char:FindFirstChild("ESPHighlight") then return end

    -- DEFINIÇÃO INTELIGENTE DA COR
    local targetColor = Config.DefaultESPColor
    if player.TeamColor then
        -- Converte a BrickColor do time para RGB real
        targetColor = player.TeamColor.Color 
    end

    -- Criação do Highlight (Método Otimizado - Vê através de tudo)
    local hl = Instance.new("Highlight")
    hl.Name = "ESPHighlight"
    hl.Adornee = char
    hl.Parent = char
    hl.FillTransparency = 1 -- Apenas Borda
    hl.OutlineColor = targetColor
    hl.OutlineTransparency = 0
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop -- Vê através das paredes!
end

local function UpdateAllESP()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            if Config.ESPEnabled then
                ApplyESP(plr)
            else
                if plr.Character then RemoveESP(plr.Character) end
            end
        end
    end
end

------------------------------------------------------------
--                      HITBOX CORE (INTACTO)              --
------------------------------------------------------------

local function safeSetPartProps(part, props)
    if not part or not part:IsA("BasePart") then return end
    local ok, err = pcall(function()
        for k, v in pairs(props) do
            part[k] = v
        end
    end)
    if not ok then
        warn("safeSetPartProps error:", err)
    end
end

local function RestorePlayer(player)
    if not player or not player.Character then return end
    local char = player.Character
    
    -- Restaura Hitbox
    for _, child in pairs(char:GetChildren()) do
        if child:IsA("BasePart") and OriginalSizes[child] then
            safeSetPartProps(child, {
                Size = OriginalSizes[child],
                Transparency = 0,
                CanCollide = true,
                Massless = false
            })
            OriginalSizes[child] = nil
        end
    end
    
    if not Config.ESPEnabled then RemoveESP(char) end
end

local function RestoreAll()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            RestorePlayer(plr)
        end
    end
    UpdateAllESP() -- Atualiza ESP também
end

local function findTargetPart(char, target)
    if not char then return nil end
    local p = char:FindFirstChild(target)
    if p and p:IsA("BasePart") then return p end
    if target == "Torso" then
        return char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    end
    return char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
end

local function ApplyHitbox(player)
    if not Config.Enabled then return end
    if not player or not player.Character then return end
    
    -- Checagem de Time da Hitbox (mantida)
    if Config.IgnoreTeam and player.Team == LocalPlayer.Team then
        RestorePlayer(player)
        return
    end

    local part = findTargetPart(player.Character, Config.TargetPart)
    if part and part:IsA("BasePart") then
        if not OriginalSizes[part] then
            OriginalSizes[part] = part.Size
        end

        local desired = Vector3.new(Config.HitboxSize, Config.HitboxSize, Config.HitboxSize)

        if part.Size ~= desired then
            safeSetPartProps(part, { Size = desired, CanCollide = false, Massless = true })
        end
        if part.Transparency ~= Config.HitboxTransparency then
            safeSetPartProps(part, { Transparency = Config.HitboxTransparency })
        end
    end
end

-- Loop Principal
RunService.RenderStepped:Connect(function()
    -- Lógica Hitbox
    if Config.Enabled then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer then
                ApplyHitbox(plr)
            end
        end
    end
    
    -- Verificação de Segurança do ESP (Garante que se aplica em novos jogadores rapidamente)
    if Config.ESPEnabled then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                if not plr.Character:FindFirstChild("ESPHighlight") then
                    ApplyESP(plr)
                end
            end
        end
    end
end)

-- Eventos de Player (Para limpeza e aplicação inicial)
Players.PlayerRemoving:Connect(function(plr)
    RestorePlayer(plr)
end)

Players.PlayerAdded:Connect(function(plr)
    if plr.Character then
        ApplyESP(plr) 
        plr.CharacterRemoving:Connect(function() RestorePlayer(plr) end)
    end
    
    plr.CharacterAdded:Connect(function(char)
        task.wait(0.2) 
        if Config.ESPEnabled then ApplyESP(plr) end
        if not Config.Enabled then RestorePlayer(plr) end
    end)
end)

for _, plr in pairs(Players:GetPlayers()) do
    if plr ~= LocalPlayer then
        if plr.Character then
            if Config.ESPEnabled then ApplyESP(plr) end
            plr.CharacterRemoving:Connect(function() RestorePlayer(plr) end)
        end
        plr.CharacterAdded:Connect(function(char)
            task.wait(0.2)
            if Config.ESPEnabled then ApplyESP(plr) end
        end)
    end
end

