local function CreateSlider(name, min, max, default, callback, order)
    local Container = Instance.new("Frame")
    Container.Size = UDim2.new(1,0,0,45); Container.BackgroundTransparency = 1; Container.LayoutOrder = order; Container.Parent = MainFrame

    local Title = Instance.new("TextLabel"); Title.Size = UDim2.new(1,0,0,20); Title.BackgroundTransparency = 1; Title.Text = name; Title.TextColor3 = Color3.fromRGB(200,200,200); Title.Font = Enum.Font.GothamMedium; Title.TextSize = 13; Title.TextXAlignment = Enum.TextXAlignment.Left; Title.Parent = Container
    local ValueLabel = Instance.new("TextLabel"); ValueLabel.Size = UDim2.new(1,0,0,20); ValueLabel.BackgroundTransparency = 1; ValueLabel.Text = tostring(default); ValueLabel.TextColor3 = Color3.fromRGB(120,120,255); ValueLabel.Font = Enum.Font.GothamBold; ValueLabel.TextSize = 13; ValueLabel.TextXAlignment = Enum.TextXAlignment.Right; ValueLabel.Parent = Container

    local SliderBG = Instance.new("Frame"); SliderBG.Size = UDim2.new(1,0,0,4); SliderBG.Position = UDim2.new(0,0,0.75,0); SliderBG.BackgroundColor3 = Color3.fromRGB(45,45,50); SliderBG.BorderSizePixel = 0; SliderBG.Parent = Container
    local Corn1 = Instance.new("UICorner"); Corn1.CornerRadius = UDim.new(1,0); Corn1.Parent = SliderBG

    local norm = 0
    if max ~= min then norm = (default - min)/(max - min) then end
    local SliderFill = Instance.new("Frame"); SliderFill.Size = UDim2.new(math.clamp(norm,0,1),0,1,0); SliderFill.BackgroundColor3 = Color3.fromRGB(90,90,220); SliderFill.BorderSizePixel = 0; SliderFill.Parent = SliderBG
    local Corn2 = Instance.new("UICorner"); Corn2.CornerRadius = UDim.new(1,0); Corn2.Parent = SliderFill

    local Trigger = Instance.new("TextButton"); Trigger.Size = UDim2.new(1,0,2,0); Trigger.Position = UDim2.new(0,0,-0.5,0); Trigger.BackgroundTransparency = 1; Trigger.Text = ""; Trigger.Parent = SliderBG

    local dragging = false
    local function Update(input)
        if max == min then return end
        local pos = math.clamp((input.Position.X - SliderBG.AbsolutePosition.X) / SliderBG.AbsoluteSize.X, 0, 1)
        local value = math.floor((min + (max - min) * pos) * 10) / 10
        TweenService:Create(SliderFill, TweenInfo.new(0.05), {Size = UDim2.new(pos,0,1,0)}):Play()
        ValueLabel.Text = tostring(value)
        callback(value)
    end

    Trigger.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; Update(input) end
    end)
    UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
    UserInputService.InputChanged:Connect(function(input) if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then Update(input) end end)
end

local function CreateToggleButton(text, defaultState, callback, order)
    local Button = Instance.new("TextButton")
    Button.Size = UDim2.new(1,0,0,32)
    Button.BackgroundColor3 = defaultState and Color3.fromRGB(60,160,60) or Color3.fromRGB(40,40,45)
    Button.Text = text .. "  [" .. (defaultState and "ON" or "OFF") .. "]"
    Button.TextColor3 = Color3.fromRGB(255,255,255)
    Button.Font = Enum.Font.GothamBold
    Button.TextSize = 13
    Button.LayoutOrder = order
    Button.AutoButtonColor = false
    Button.Parent = MainFrame

    local Corner = Instance.new("UICorner"); Corner.CornerRadius = UDim.new(0,6); Corner.Parent = Button

    local currentState = defaultState
    Button.MouseButton1Click:Connect(function()
        currentState = not currentState
        Button.Text = text .. "  [" .. (currentState and "ON" or "OFF") .. "]"
        local targetColor = currentState and Color3.fromRGB(60,160,60) or Color3.fromRGB(40,40,45)
        TweenService:Create(Button, TweenInfo.new(0.3), {BackgroundColor3 = targetColor}):Play()
        callback(currentState)
    end)
    return Button
end

